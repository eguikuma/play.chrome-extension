{
  "name": "play.chrome-extension",
  "description": "Gmailのプライバシーを保護するシールド機能を提供します",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "clean": "rm -rf distributions",
    "package:deps": "ncu",
    "package:update": "ncu -i",
    "package:update:force": "ncu -u",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier": "prettier --check \"**/*.{ts,js,css,html,md,json}\"",
    "prettier:fix": "prettier --write \"**/*.{ts,js,css,html,md,json}\"",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm-run-all prettier:fix eslint:fix tsc test clean build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/chrome": "^0.1.36",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.3.0",
    "jsdom": "^28.0.0",
    "lodash": "^4.17.23",
    "npm-check-updates": "^19.3.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "type-fest": "^5.4.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
